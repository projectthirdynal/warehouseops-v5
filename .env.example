APP_NAME=WarehouseOps
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=warehouseops
DB_USERNAME=warehouseops
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@warehouseops.local"
MAIL_FROM_NAME="${APP_NAME}"

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Courier API Keys
JNT_API_URL=https://openapi.jtexpress.ph/api
JNT_API_KEY=
JNT_API_SECRET=
JNT_WEBHOOK_SECRET=

FLASH_API_URL=https://open-api.flashexpress.com
FLASH_MCH_ID=
FLASH_SECRET_KEY=

VITE_APP_NAME="${APP_NAME}"
